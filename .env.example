NORMALDOCS_WORKER_ORIGIN=https://api.docs.example.com
NORMALDOCS_FRONTEND_ORIGIN=https://docs.example.com
NORMALDOCS_COMMENTS_ORIGIN=https://comments.pics.example.com
NORMALDOCS_PRINT_ORIGIN=https://print.example.com
NORMALDOCS_DAEMON_DEVICE_ID=normaldocs-local
NORMALDOCS_DAEMON_DEVICE_NAME=NormalDocs Daemon
NORMALDOCS_LOCAL_LIBRARY_DIR=./documents
NORMALDOCS_LOCAL_PREVIEW_DIR=./previews
# Optional fallback for PPT/PPTX and legacy Office formats. Packaged builds can bundle LibreOffice Portable.
LIBREOFFICE_BIN=
NORMALDOCS_DAEMON_SECRET=
# Worker-side secret should match NORMALDOCS_DAEMON_SECRET when configuring Cloudflare.
DAEMON_SECRET=
DELETE_PIN_HASH=sha256:<hex-encoded-delete-pin-hash>
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=normaldocs
