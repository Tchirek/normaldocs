{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://docs.example.com",
          "http://localhost:5174"
        ],
        "methods": [
          "GET",
          "HEAD",
          "PUT"
        ],
        "headers": [
          "content-type",
          "content-length",
          "x-amz-content-sha256",
          "x-amz-date"
        ]
      },
      "exposeHeaders": [
        "etag"
      ],
      "maxAgeSeconds": 600
    }
  ]
}
