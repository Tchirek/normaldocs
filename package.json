{
  "name": "normaldocs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "NormalDocs workspace root",
  "workspaces": [
    "packages/frontend",
    "packages/worker",
    "packages/daemon"
  ],
  "scripts": {
    "build:frontend": "npm --workspace packages/frontend run build",
    "build:worker": "npm --workspace packages/worker run build",
    "build:daemon": "npm --workspace packages/daemon run build",
    "build:all": "npm run build:worker && npm run build:frontend && npm run build:daemon",
    "dev:frontend": "npm --workspace packages/frontend run dev",
    "dev:worker": "npm --workspace packages/worker run dev",
    "dev:daemon": "npm --workspace packages/daemon run dev"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
