{
  "rules": [
    {
      "id": "abort-incomplete-multipart-uploads",
      "enabled": true,
      "conditions": {
        "type": "LifecycleRuleConditions"
      },
      "abortMultipartUploadsTransition": {
        "condition": {
          "type": "Age",
          "maxAge": 86400
        }
      }
    }
  ]
}
